# 测试环境配置示例
# 复制此文件为 .env 并填入实际值

# API基础URL
TEST_BASE_URL=http://localhost:8787

# 测试模式：mock（使用mock数据）或 real（调用真实API）
TEST_MODE=mock

# 请求超时时间（秒）
TEST_TIMEOUT=10

# 是否打印详细日志
TEST_VERBOSE=true

# 测试用户ID
TEST_USER_ID=test_user_123

# 测试Stripe Customer ID
TEST_CUSTOMER_ID=cus_test_xxx

# Stripe测试密钥（仅用于集成测试）
STRIPE_SECRET_KEY=sk_test_xxx

