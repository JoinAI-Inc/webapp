# ============================================
# Cloudflare Workers 本地开发环境变量示例
# ============================================
# 
# 使用说明：
# 1. 复制此文件为 .env（或 .dev.vars）
# 2. 填入你的真实密钥
# 3. 本地开发：wrangler dev 会自动读取 .env
# 4. 生产环境：使用 wrangler secret put <KEY>
#

# Stripe Secret Key（必需）
# 获取地址：https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Secret（可选，仅用于本地测试 webhook）
# 获取方式：运行 'stripe listen --forward-to localhost:8787/api/webhook'
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

