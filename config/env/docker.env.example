# Copy this file to .env.docker before running docker compose.
#
# Naming rule:
# - *_ORIGIN values are scheme + host + optional port, without a trailing slash.
# - PUBLIC/API/AUTH/PAYMENT names describe why the address is used.
# - INTERNAL_* values are Docker-network addresses used between containers.
# - Framework-specific names such as NEXTAUTH_URL and WORKER_SECRET are mapped
#   in docker-compose.yml and normally do not need to be set here.

# -----------------------------------------------------------------------------
# Public origins by responsibility
# -----------------------------------------------------------------------------
# Auth.js/NextAuth public origin. Google redirect URI is:
#   ${AUTH_PUBLIC_ORIGIN}/api/auth/callback/google
AUTH_PUBLIC_ORIGIN=http://localhost:3003

# API CORS allowlist origin for browser requests coming from BACC.
API_ALLOWED_ORIGIN=http://localhost:3003

# Browser redirect base for Stripe/payment success and cancel URLs.
PAYMENT_RETURN_ORIGIN=http://localhost:3003

# Docker-internal API origin used by BACC server routes.
INTERNAL_API_ORIGIN=http://api:3001

# Optional runtime proxy for server-side calls to Google/Stripe/model providers.
# On Linux Docker, use host.docker.internal to reach a proxy running on the host.
# Example for Clash/mihomo mixed-port 7890:
# OUTBOUND_HTTP_PROXY=http://host.docker.internal:7890
OUTBOUND_HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,api,postgres,worker,bacc,admin

# -----------------------------------------------------------------------------
# Published host ports
# -----------------------------------------------------------------------------
POSTGRES_PORT=25432
API_PORT=3001
BACC_PORT=3003
ADMIN_PORT=3004

# -----------------------------------------------------------------------------
# Database
# Container-to-container URLs must use postgres:5432, not the host published port.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webapp
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/webapp
DIRECT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/webapp

# -----------------------------------------------------------------------------
# Application secrets
# Generate each value with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=change-me
API_JWT_SECRET=change-me
INTERNAL_SERVICE_SECRET=change-me
ADMIN_SECRET=admin_secret_123
NEXT_PUBLIC_ADMIN_API_TOKEN=admin_secret_123

# -----------------------------------------------------------------------------
# OAuth providers
# BACC uses NextAuth/Auth.js. Configure Google redirect URI from
# AUTH_PUBLIC_ORIGIN:
#   ${AUTH_PUBLIC_ORIGIN}/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Redis queue metadata/API status
# Current code uses Upstash Redis REST; a plain redis:// URL is not enough.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QUEUE_MAX_RETRIES=3
TASK_REDIS_TTL=86400

# -----------------------------------------------------------------------------
# Worker image generation
# -----------------------------------------------------------------------------
QUEUE_WORKER_INTERVAL_MS=30000
QUEUE_WORKER_BATCH_SIZE=5
QUEUE_WORKER_LOCK_TTL=120
QUEUE_WORKER_LOCK_RENEW_MS=30000
NANO_BANANA_API_KEY=
NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NANO_BANANA_TEMPLATE_MODELS=gemini-3-pro-image-preview-2k
TEMPLATE_INPUT_IMAGE_MAX_DIMENSION=1536
TEMPLATE_INPUT_IMAGE_JPEG_QUALITY=82

# -----------------------------------------------------------------------------
# Cloudflare R2 storage
# NEXT_PUBLIC_IMAGE_URL is the browser-visible base URL used for static/card
# assets in BACC. R2_PUBLIC_DOMAIN is used by backend storage uploads.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=webapp
R2_PUBLIC_DOMAIN=
NEXT_PUBLIC_IMAGE_URL=https://pub-cfc37210b6a543b492b7f0e494faac09.r2.dev/bacc/image

# -----------------------------------------------------------------------------
# BACC public build-time values
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APP_ID=bacc
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# -----------------------------------------------------------------------------
# Stripe
# Optional until payments/webhooks are enabled.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Backward-compatible names
# Usually leave these unset. docker-compose.yml maps the clearer variables above
# into these framework-specific names.
# -----------------------------------------------------------------------------
# AUTH_URL=
# NEXTAUTH_URL=
# NEXTAUTH_SECRET=
# APP_URL=
# BACC_ORIGIN=
# PUBLIC_WEB_ORIGIN=
# API_BACKEND_URL=
# WORKER_SECRET=
# JWT_SECRET=
