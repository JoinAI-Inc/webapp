# App
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_APP_ID=your_app_id_here
NEXT_PUBLIC_IMAGE_URL=https://your-public-domain.r2.dev/bacc/image
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Auth.js / NextAuth
AUTH_URL=http://localhost:3003
AUTH_SECRET=your-auth-secret-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=your-auth-secret-use-openssl-rand-base64-32

# Backend API used by BACC server routes.
API_BACKEND_URL=http://localhost:3001

# Internal API request signing. Must match apps/api WORKER_SECRET.
WORKER_SECRET=change-me

# Test routes only; worker owns production image generation.
NANO_BANANA_API_KEY=

# Cloudflare/R2 compatibility for local or Cloudflare deployments.
# Docker production image generation/storage is owned by worker/admin.
R2_ACCOUNT_ID=your_r2_account_id_here
R2_BUCKET_NAME=your_bucket_name_here
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_PUBLIC_DOMAIN=https://your-public-domain.r2.dev
