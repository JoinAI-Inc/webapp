# Platform SDK Configuration
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_APP_ID=your_app_id_here

# Debug Logging (set to 'true' to enable detailed debug logs)
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google AI API
NANO_BANANA_API_KEY=your_google_ai_api_key_here

# Upstash Redis (Queue System)
UPSTASH_REDIS_REST_URL=https://golden-piglet-31092.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXl0AAIncDJmMmNmMDg2ODYyODU0YjIzYTE5NzM5MjQ5ZDMzMDVkY3AyMzEwOTI

# Queue Configuration (Optional)
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000
QUEUE_WORKER_INTERVAL=10000
WORKER_SECRET=change-me-in-production


# Database - PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database?schema=public
DIRECT_DATABASE_URL=postgresql://user:password@host:port/database?schema=public

# JWT Secret (IMPORTANT: Use a strong random secret in production)
JWT_SECRET=your-strong-random-jwt-secret-here

# Google OAuth Backend
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
OAUTH_CALLBACK_BASE=http://localhost:3003/auth/callback

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_r2_account_id_here
R2_BUCKET_NAME=your_bucket_name_here
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_PUBLIC_DOMAIN=https://your-public-domain.r2.dev

# API Backend URL (for production deployment)
API_BACKEND_URL=http://localhost:3001

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=your-nextauth-secret-use-openssl-rand-base64-32
