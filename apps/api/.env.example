# Database
DATABASE_URL="postgresql://..."
DIRECT_DATABASE_URL="postgresql://..."

# Redis
REDIS_URL="redis://localhost:6379"

# Queue Configuration
QUEUE_MAX_RETRIES=3           # 任务最大重试次数
TASK_REDIS_TTL=3600          # 任务 Redis TTL（秒），默认 1 小时

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Image generation API
NANO_BANANA_API_KEY=...
NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NANO_BANANA_TEMPLATE_MODELS=gemini-3-pro-image-preview-2k

# R2 Storage
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
R2_PUBLIC_DOMAIN=https://...

# Server
PORT=3001
