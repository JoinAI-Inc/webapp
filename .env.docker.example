# Copy this file to .env.docker before running docker compose.

# Local Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webapp
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/webapp
DIRECT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/webapp

# Published service ports
API_PORT=3001
BACC_PORT=3003
ADMIN_PORT=3004

# API service
NODE_ENV=production
PORT=3001
BACC_ORIGIN=http://localhost:3003
APP_URL=http://localhost:3003
JWT_SECRET=change-me
WORKER_SECRET=change-me
OAUTH_CALLBACK_BASE=http://localhost:3003/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Shared Redis queue metadata/API status.
# Current code uses Upstash Redis REST, so a plain local redis:// URL is not enough.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QUEUE_MAX_RETRIES=3
TASK_REDIS_TTL=86400

# Worker-only image generation and R2 storage
QUEUE_WORKER_INTERVAL_MS=30000
QUEUE_WORKER_BATCH_SIZE=5
QUEUE_WORKER_LOCK_TTL=120
QUEUE_WORKER_LOCK_RENEW_MS=30000
NANO_BANANA_API_KEY=
NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NANO_BANANA_TEMPLATE_MODELS=gemini-3-pro-image-preview-2k
TEMPLATE_INPUT_IMAGE_MAX_DIMENSION=1536
TEMPLATE_INPUT_IMAGE_JPEG_QUALITY=82
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=webapp
R2_PUBLIC_DOMAIN=

# BACC Next app
API_BACKEND_URL=http://api:3001
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=change-me
AUTH_SECRET=change-me
NEXT_PUBLIC_IMAGE_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APP_ID=bacc
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Admin app
ADMIN_SECRET=admin_secret_123
NEXT_PUBLIC_ADMIN_API_TOKEN=admin_secret_123
